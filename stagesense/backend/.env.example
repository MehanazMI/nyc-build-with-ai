# StageSense Backend Environment Variables
# Copy this to .env and fill in your values

# ──────────────────────────────────────────────────────────────────────────────
# OPTION A: Google AI Studio (Recommended — Free, works immediately)
# Get key from: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-api-key-here

# ──────────────────────────────────────────────────────────────────────────────
# OPTION B: Google Cloud Vertex AI (requires Live API to be enabled on project)
# Comment out GOOGLE_API_KEY above and uncomment these:
# ──────────────────────────────────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=ai-hack-489018
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true
# MODEL_ID=gemini-live-2.5-flash-preview-native-audio-09-2025

# ──────────────────────────────────────────────────────────────────────────────
# Optional overrides
# ──────────────────────────────────────────────────────────────────────────────
# MODEL_ID=gemini-2.0-flash-live-001   # AI Studio default (half-cascade, TEXT)
# MODEL_ID=gemini-2.5-flash-preview-native-audio  # Vertex native audio
